# 环境变量示例
# 复制此文件为 .env.local 并填入你的 API key

# ===================
# Hybrid Model Strategy（混合模型策略）
# ===================
# 为不同 Agent 配置独立的模型，实现成本优化。
# PM + Reviewer 默认使用 Haiku（便宜 ~55%），Dev / DA / Arbiter 默认 Sonnet。
#
# 可选值（Anthropic）：
#   claude-3-5-haiku-20241022   ← 快速、便宜，适合规划/审查
#   claude-3-5-sonnet-20241022  ← 强推理，适合代码生成/仲裁
#
# 任务复杂度自动升级（PM only）：
#   描述包含安全/性能/架构等关键词 → PM 自动升级到 Sonnet
#   描述 < 50 字且无关键词 → 保持 Haiku
#
# CLAWCOMPANY_PM_MODEL=claude-3-5-haiku-20241022
# CLAWCOMPANY_DEV_MODEL=claude-3-5-sonnet-20241022
# CLAWCOMPANY_REVIEWER_MODEL=claude-3-5-haiku-20241022
# CLAWCOMPANY_DA_MODEL=claude-3-5-sonnet-20241022
# CLAWCOMPANY_ARBITER_MODEL=claude-3-5-sonnet-20241022


# Dev agent 通过 opencode ACP 写代码时需要 GitHub Copilot 认证
# 获取方式：gh auth token
GITHUB_TOKEN=your-github-token-here

# Dev agent 写代码的工作目录（默认为项目根目录）
# CLAWCOMPANY_CWD=/absolute/path/to/project

# ===================
# GLM (智谱 AI) 配置 - 推荐
# ===================
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4  # 或 glm-4-flash, glm-4-plus

# ===================
# Mock 模式（用于 Demo 录制）
# ===================
# 启用后使用预设的快速响应，不调用真实 API
# USE_MOCK_LLM=true

# ===================
# OpenAI 配置 - 备选
# ===================
# OPENAI_API_KEY=your-openai-api-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# ===================
# 通用配置
# ===================
# 温度参数 (0-2)
LLM_TEMPERATURE=0.7

# 最大 token 数
LLM_MAX_TOKENS=2000

# ===================
# 项目配置
# ===================
# 项目根目录（用于保存生成的代码）
PROJECT_ROOT=/Users/felixmiao/Projects/ClawCompany/generated

# ===================
# API 认证配置
# ===================
# Agent API 写操作（PUT/DELETE）需要 API Key 认证
# 客户端需通过 X-API-Key 或 Authorization: Bearer <key> 请求头传入
AGENT_API_KEY=your-agent-api-key-here

# ⚠️  已废弃 / DEPRECATED
# NEXT_PUBLIC_AGENT_API_KEY 已移除。API Key 不再暴露于前端 JS bundle。
# 前端通过 same-origin Next.js API Routes 访问 dashboard 数据，无需传递密钥。
# 如果你的 .env.local 中仍有此变量，可以安全删除它。
# NEXT_PUBLIC_AGENT_API_KEY=（已废弃，请删除）

# ===================
# 加密配置（必须设置，否则加密功能静默失败）
# ===================
# 32 位加密密钥（可用: openssl rand -hex 16）
ENCRYPTION_KEY=your-32-char-encryption-key-here
# 加密盐值（可用: openssl rand -hex 8）
ENCRYPTION_SALT=your-encryption-salt-here

# ===================
# OpenClaw Gateway 配置
# ===================
# ⚠️  Vercel 部署必须设置为公网可访问的 Gateway URL！
# localhost 在 Vercel Serverless 环境中无效。
# Docker 部署可用 ws://host.docker.internal:18789
OPENCLAW_GATEWAY_URL=wss://your-gateway-domain.example.com
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ── Redis Pub/Sub (多 Worker / Vercel 部署必须配置) ──────────────────────────
# Vercel 多 Worker 下，POST 和 SSE GET 可能落在不同 Worker 实例，
# 内存 EventEmitter 无法跨进程传递事件。
# 设置此变量启用 Redis Pub/Sub 模式（需要安装 ioredis: npm i ioredis）。
#
# 推荐服务：Upstash Redis（https://upstash.com，有免费额度，Vercel 集成友好）
# 单实例部署（Docker / 开发环境）无需设置此变量，EventEmitter 即可正常工作。
#
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:<password>@<host>:<port>   # Upstash TLS 格式
