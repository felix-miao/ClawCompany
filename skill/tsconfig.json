{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@ai-team-demo/lib/*": ["../ai-team-demo/src/lib/*"],
      "@/*": ["../ai-team-demo/src/*"],
      "@/lib/*": ["../ai-team-demo/src/lib/*"],
      "@/types/*": ["../ai-team-demo/src/types/*"]
    }
  },
  "include": [
    "src/**/*",
    "../ai-team-demo/src/lib/**/*",
    "../ai-team-demo/src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "../ai-team-demo/src/lib/**/__tests__/**"
  ]
}
