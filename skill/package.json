{
  "name": "clawcompany",
  "version": "1.0.0",
  "description": "AI 虚拟团队协作系统 - 一人企业家，无限可能",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "ai-team",
    "automation",
    "code-generation",
    "productivity",
    "agents",
    "clawhub"
  ],
  "author": "Felix Miao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/felix-miao/ClawCompany.git"
  },
  "bugs": {
    "url": "https://github.com/felix-miao/ClawCompany/issues"
  },
  "homepage": "https://github.com/felix-miao/ClawCompany#readme",
  "dependencies": {
    "openclaw": "latest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "clawhub": {
    "category": "productivity",
    "tags": ["ai-team", "automation", "coding", "agents"],
    "icon": "🦞",
    "displayName": "ClawCompany",
    "description": "AI 虚拟团队协作系统，实现一人企业家模式",
    "examples": [
      "创建一个登录页面",
      "创建一个计算器应用",
      "创建一个 Todo List"
    ],
    "requirements": {
      "env": ["GLM_API_KEY"],
      "optional": ["GLM_MODEL", "PROJECT_ROOT"]
    },
    "compatibility": {
      "openclaw": ">=1.0.0",
      "node": ">=18.0.0"
    }
  }
}
