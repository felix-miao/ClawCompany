# 环境变量示例
# 复制此文件为 .env.local 并填入你的 API key

# ===================
# GLM (智谱 AI) 配置 - 推荐
# ===================
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4  # 或 glm-4-flash, glm-4-plus

# ===================
# Mock 模式（用于 Demo 录制）
# ===================
# 启用后使用预设的快速响应，不调用真实 API
# USE_MOCK_LLM=true

# ===================
# OpenAI 配置 - 备选
# ===================
# OPENAI_API_KEY=your-openai-api-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# ===================
# 通用配置
# ===================
# 温度参数 (0-2)
LLM_TEMPERATURE=0.7

# 最大 token 数
LLM_MAX_TOKENS=2000

# ===================
# 项目配置
# ===================
# 项目根目录（用于保存生成的代码）
PROJECT_ROOT=/Users/felixmiao/Projects/ClawCompany/ai-team-demo/generated
